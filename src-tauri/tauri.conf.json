{
  "$schema": "https://schema.tauri.app/config/2.0",
  "productName": "Kibrary",
  "version": "0.1.0",
  "identifier": "io.raph.kibrary",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      { "title": "Kibrary", "width": 1280, "height": 800, "minWidth": 800, "minHeight": 600 }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
