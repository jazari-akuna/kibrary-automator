[Application]
name=io.raph.kibrary
runtime=org.gnome.Platform/x86_64/47
sdk=org.gnome.Sdk/x86_64/47
command=kibrary

[Context]
shared=network;ipc;
sockets=x11;wayland;fallback-x11;
devices=dri;
filesystems=home;

[Session Bus Policy]
org.freedesktop.Flatpak=talk
org.freedesktop.secrets=talk

[Extension io.raph.kibrary.Debug]
directory=lib/debug
autodelete=true
no-autodownload=true

[Build]
built-extensions=io.raph.kibrary.Debug;